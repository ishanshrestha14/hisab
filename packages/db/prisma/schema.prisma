generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Currency {
  USD
  GBP
  EUR
  NPR
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
}

enum RecurrenceInterval {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum ExpenseCategory {
  SOFTWARE
  HARDWARE
  TRAVEL
  MEALS
  OFFICE
  MARKETING
  PROFESSIONAL_SERVICES
  OTHER
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
  CONVERTED
}

// ─── Better Auth required tables ──────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  pan              String?   // Nepal PAN number (e.g. "123456789")
  vatNumber        String?   // Nepal VAT registration number
  logoUrl          String?   // URL to user's business logo for invoices
  invoiceTemplate  String    @default("classic") // "classic" | "modern" | "minimal"
  brandColor       String    @default("#f59e0b")  // hex accent color for PDF
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]

  clients            Client[]
  invoices           Invoice[]
  quotes             Quote[]
  recurringInvoices  RecurringInvoice[]
  timeEntries        TimeEntry[]
  expenses           Expense[]
  auditLogs          AuditLog[]
  idempotencyKeys    IdempotencyKey[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
}

// ─── App models ───────────────────────────────────────────────────────────────

model Client {
  id              String    @id @default(cuid())
  userId          String
  name            String
  email           String
  company         String?
  country         String?
  defaultCurrency Currency  @default(USD)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  invoices          Invoice[]
  quotes            Quote[]
  recurringInvoices RecurringInvoice[]
  timeEntries       TimeEntry[]
  expenses          Expense[]

  @@index([userId])
}

model Invoice {
  id          String        @id @default(cuid())
  userId      String
  clientId    String
  // Public token for /portal/:token — never expose the real id
  token       String        @unique @default(cuid())
  number      String        // e.g. "INV-0001"
  status      InvoiceStatus @default(DRAFT)
  currency    Currency      @default(USD)
  issueDate   DateTime      @default(now())
  dueDate     DateTime
  notes       String?
  // Cached NPR rate at the time of sending — stored so PDF always shows original rate
  nprRate     Float?
  // TDS percentage withheld by the client (e.g. 15 for 15%). 0 = no TDS applicable.
  tdsPercent  Float         @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  client      Client      @relation(fields: [clientId], references: [id])
  lineItems   LineItem[]
  payments    Payment[]
  timeEntries TimeEntry[]
  quote       Quote?

  @@unique([userId, number])
  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([clientId])
  @@index([dueDate, status])
}

model LineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Float
  unitPrice   Float
  // total = quantity * unitPrice (computed but stored for query efficiency)
  total       Float

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// ─── Audit log ────────────────────────────────────────────────────────────────

model RecurringInvoice {
  id          String              @id @default(cuid())
  userId      String
  clientId    String
  currency    Currency            @default(USD)
  interval    RecurrenceInterval
  nextRunAt   DateTime            // when the next invoice should be generated
  daysBefore  Int                 @default(0) // due date = nextRunAt + daysBefore
  notes       String?
  active      Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  user      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  client    Client                    @relation(fields: [clientId], references: [id])
  lineItems RecurringInvoiceLineItem[]

  @@index([userId])
  @@index([nextRunAt, active])
}

model RecurringInvoiceLineItem {
  id                  String           @id @default(cuid())
  recurringInvoiceId  String
  description         String
  quantity            Float
  unitPrice           Float
  total               Float

  recurringInvoice RecurringInvoice @relation(fields: [recurringInvoiceId], references: [id], onDelete: Cascade)

  @@index([recurringInvoiceId])
}

model Quote {
  id         String      @id @default(cuid())
  userId     String
  clientId   String
  number     String      // e.g. "QT-0001"
  status     QuoteStatus @default(DRAFT)
  currency   Currency    @default(USD)
  issueDate  DateTime    @default(now())
  expiryDate DateTime
  notes      String?
  // Set when converted to invoice
  invoiceId  String?     @unique
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  client    Client     @relation(fields: [clientId], references: [id])
  lineItems QuoteLineItem[]
  invoice   Invoice?   @relation(fields: [invoiceId], references: [id])

  @@unique([userId, number])
  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([clientId])
}

model QuoteLineItem {
  id          String @id @default(cuid())
  quoteId     String
  description String
  quantity    Float
  unitPrice   Float
  total       Float

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}

model Payment {
  id        String   @id @default(cuid())
  invoiceId String
  amount    Float    // amount paid in the invoice's currency
  paidAt    DateTime @default(now())
  notes     String?
  createdAt DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model TimeEntry {
  id          String   @id @default(cuid())
  userId      String
  clientId    String
  description String
  hours       Float
  hourlyRate  Float
  currency    Currency @default(USD)
  date        DateTime @default(now())
  // Set when this entry has been billed — locks the entry from edits/deletes
  invoiceId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  client  Client  @relation(fields: [clientId], references: [id])
  invoice Invoice? @relation(fields: [invoiceId], references: [id])

  @@index([userId])
  @@index([userId, invoiceId])
  @@index([clientId])
}

model Expense {
  id          String          @id @default(cuid())
  userId      String
  clientId    String?
  category    ExpenseCategory @default(OTHER)
  description String
  amount      Float
  currency    Currency        @default(USD)
  date        DateTime        @default(now())
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id])

  @@index([userId])
  @@index([userId, date])
  @@index([clientId])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  entityType String   // e.g. "invoice"
  entityId   String
  action     String   // e.g. "invoice.created"
  before     Json?    // state snapshot before the change
  after      Json?    // state snapshot after the change
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, entityType])
  @@index([entityId])
  @@index([createdAt])
}

// ─── Idempotency keys ─────────────────────────────────────────────────────────
// Caches POST /api/invoices responses for 24h so duplicate submissions are safe.

model IdempotencyKey {
  id         String   @id @default(cuid())
  key        String
  userId     String
  statusCode Int
  response   Json
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([key, userId])
  @@index([createdAt]) // used by a future cleanup job to prune expired keys
}

// ─── Exchange rate cache ───────────────────────────────────────────────────────
// One row per base currency per day — fetched from exchangerate.host

model ExchangeRate {
  id        String   @id @default(cuid())
  base      Currency
  rateToNPR Float    // 1 base = X NPR
  fetchedAt DateTime @default(now())
  date      String   // "YYYY-MM-DD" — used as cache key

  @@unique([base, date])
}
