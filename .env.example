# ─── Database ─────────────────────────────────────────────────────────────────
# For local dev:
DATABASE_URL="postgresql://postgres:password@localhost:5432/hisab"
# For Docker (docker-compose uses this to set the Postgres container password):
POSTGRES_PASSWORD="change-me"

# ─── Better Auth ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET="replace-me-with-a-32-char-random-string"
BETTER_AUTH_URL="http://localhost:3001"

# ─── Google OAuth (optional for dev, required in prod) ────────────────────────
# Create at https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── URLs ─────────────────────────────────────────────────────────────────────
WEB_URL="http://localhost:5173"
PORT=3001

# ─── Frontend (Vite — must be prefixed VITE_) ─────────────────────────────────
VITE_API_URL="http://localhost:3001"

# ─── Email — Resend (Week 5) ──────────────────────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="Hisab <noreply@yourdomain.com>"

